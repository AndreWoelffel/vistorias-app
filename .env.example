# Copie para .env local ou defina no painel Vercel / Netlify (Environment variables).
# Use apenas chave anon/public (sb_publishable_... ou JWT anon). Nunca sb_secret_ no browser.

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Não use NEXT_PUBLIC_* neste projeto — o cliente lê só VITE_* (ver supabaseClient.ts).
